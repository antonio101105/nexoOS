        config    FILELOGDIR
            string "Inst file dirt"
            default "$JHALFSDIR/$FILELOGDIRBASE"

        config    ICALOGDIR
            string "ICA logs dir."
            default "$LOGDIR/ICA"

        config    MKFILE
            string "Makefile"
            default "$JHALFSDIR/Makefile"

        config    XSL
            string "XSL stylesheet"
            default "lfs.xsl"

        config    PKG_LST
